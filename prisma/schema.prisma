generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Concours {
  eprvId               String   @id
  eprvNom              String
  eprvDateDebut        String
  eprvDateFin          String
  eprvLieu             String?
  eprvEtatCode         String?
  eprvChampNiv         String?
  eprvChampionnatType  String?
  disciplineCode       String?
  eprvType             String?
  saisonAnnee          String?
  ligueCode            String?
  ligueNom             String?
  departementCode      String?
  departementNom       String?
  structureCode        String?
  structureNom         String?
  adresseCodePostal    String?
  adresseCommune       String?
  adresseLatitude      String?
  adresseLongitude     String?
  contactsMail         String?
  contactsWeb          String?
  distinction          String?
  pdf                  String?
  syncedAt             DateTime @default(now())

  @@index([saisonAnnee])
  @@index([disciplineCode])
}

model EpreuveResultat {
  eprvId               String   @id
  eprvNom              String
  eprvDateDebut        String
  eprvDateFin          String?
  eprvLieu             String?
  eprvEtat             String?
  discipline           String?
  eprvType             String?
  saisonAnnee          String?
  ligueCode            String?
  ligueNom             String?
  departementCode      String?
  structureNom         String?
  nbResultats          String?
  championnatLibelle   String?
  eprvChampNiv         String?
  eprvChampionnatType  String?
  syncedAt             DateTime @default(now())
  classements          Classement[]

  @@index([saisonAnnee])
}

model Classement {
  id               Int      @id @default(autoincrement())
  eprvId           String
  libelle          String
  epreuve          EpreuveResultat @relation(fields: [eprvId], references: [eprvId], onDelete: Cascade)
  participants     Participant[]

  @@index([eprvId])
}

model Participant {
  id            Int        @id @default(autoincrement())
  classementId  Int
  nom           String
  club          String?
  licenceCode   String?
  categorie     String?
  scoreTotal    String?
  placeQualif   String?
  placeDef      String?
  scoreDist1    String?
  scoreDist2    String?
  dix           String?
  neuf          String?
  classement    Classement @relation(fields: [classementId], references: [id], onDelete: Cascade)

  @@index([classementId])
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  type      String
  saison    String
  status    String
  message   String?
  createdAt DateTime @default(now())
}
